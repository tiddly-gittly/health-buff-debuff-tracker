title: $:/plugins/linonetwo/health-buff-debuff-tracker/components/BuffTable

\import [[$:/plugins/linonetwo/health-buff-debuff-tracker/filters/health]]
\whitespace trim

\procedure lingo-base() $:/plugins/linonetwo/health-buff-debuff-tracker/language/

\procedure columns()
[
	{
		field: 'title',
		title: 'title',
		width: 'auto',
		sort: true,
	},
	{
		field: 'startDate',
		title: 'startDate',
		width: 180,
		sort: true,
	},
]
\end

<div class="health-buff-debuff-tracker-summary-section">
<$let count={{{ [subfilter<get-all-buff>count[]] }}}>

!!! <<count>> <<lingo Buff>>

<$list filter="[<count>match[0]]" variable="ignore">
<div class="health-buff-debuff-tracker-empty-state">
  <$transclude $tiddler="$:/plugins/linonetwo/health-buff-debuff-tracker/icons/EmptyBox" size="3em"/>
  <span><<lingo EmptyBuff>></span>
</div>
</$list>

<$list filter="[<count>!match[0]]" variable="ignore">
<div class="health-buff-debuff-tracker-dynamic-table">
<$basic-table
	filter=<<get-all-buff>>
	columns=<<columns>>
	width="100%"
	height="110px"
	search="search-bar-top"
	sort="startDate title"
/>
</div>
</$list>
</$let>
</div>
