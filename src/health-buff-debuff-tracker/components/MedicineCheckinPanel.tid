title: $:/plugins/linonetwo/health-buff-debuff-tracker/components/MedicineCheckinPanel

\import [[$:/plugins/linonetwo/health-buff-debuff-tracker/filters/medicine-checkin]]
\import [[$:/plugins/linonetwo/health-buff-debuff-tracker/filters/health]]
\whitespace trim

\procedure lingo-base() $:/plugins/linonetwo/health-buff-debuff-tracker/language/

<div class="health-buff-debuff-tracker-checkin-container">

!!! <<lingo MedicineCheckin>>
<div class="health-buff-debuff-tracker-checkin-buttons">
  <$list filter=<<get-all-medicine>> variable="currentMedicine">
    <$let logTitle={{{ [<currentMedicine>addprefix[$:/plugins/linonetwo/health-buff-debuff-tracker/medicine-checkin-log/]] }}}>
      <div class="health-buff-debuff-tracker-checkin-card">
        <$button class="health-buff-debuff-tracker-checkin-btn">
          <$action-create-activity-log $logTitle=<<logTitle>> $logType="daily-count" />
          <$action-add-activity-to-log $logTitle=<<logTitle>> $logType="daily-count" />
          <$transclude $tiddler={{{ [<currentMedicine>get[icon]] }}} $mode="inline"/> <$text text={{{ [<currentMedicine>get[caption]] :else[<currentMedicine>] }}}/>
        </$button>
        <div class="health-buff-debuff-tracker-checkin-minichart">
          <$echarts $tiddler="$:/plugins/linonetwo/health-buff-debuff-tracker/ViewTemplate/MedicineCheckinMiniChart" logTitle=<<logTitle>> $height="60px" $width="100%"/>
        </div>
      </div>
    </$let>
  </$list>
</div>

!!! <<lingo TodayMedicineCheckinDetails>>
<div class="health-buff-debuff-tracker-checkin-details">
  <$let activeCheckinCount={{{ [subfilter<get-all-checkin-logs>medicinecheckinstat[today]sum[]] }}}>
    <$list filter="[<activeCheckinCount>match[0]]" variable="ignore">
      <div class="health-buff-debuff-tracker-empty-state">
        <$transclude $tiddler="$:/plugins/linonetwo/health-buff-debuff-tracker/icons/EmptyBox" size="3rem"/>
        <span><<lingo NoMedicineCheckinHistory>></span>
      </div>
    </$list>
    <$list filter="[<activeCheckinCount>!match[0]]" variable="ignore">
      <$list filter=<<get-all-checkin-logs>> variable="logTitle">
        <$let medicineTitle={{{ [<logTitle>removeprefix[$:/plugins/linonetwo/health-buff-debuff-tracker/medicine-checkin-log/]] }}}>
          <$let todayCount={{{ [<logTitle>medicinecheckinstat[today]] }}}>
            <$list filter={{{ [<todayCount>!match[0]!is[blank]] }}}>
              <div class="health-buff-debuff-tracker-medicine-log-item">
                <strong>
                  <$text text={{{ [<medicineTitle>get[caption]] :else[<medicineTitle>] }}}/>
                </strong>
                <span class="health-buff-debuff-tracker-checkin-count">
                  <$text text=<<todayCount>>/> 次
                </span>
                <$button class="health-buff-debuff-tracker-btn-small">
                  <$action-navigate $to=<<logTitle>>/>
                  <<lingo OpenHistory>>
                </$button>
              </div>
            </$list>
          </$let>
        </$let>
      </$list>
    </$list>
  </$let>
</div>

</div>
